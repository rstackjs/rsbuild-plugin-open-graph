{
  "name": "rsbuild-plugin-open-graph",
  "version": "1.1.3",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-open-graph",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-open-graph#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-open-graph/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "bump": "npx bumpp",
    "dev": "rslib -w",
    "prettier": "prettier --check ./playground ./src ./test *.ts",
    "prettier:fix": "prettier --write ./playground ./src ./test *.ts",
    "test": "rstest",
    "test:watch": "rstest watch",
    "lint": "rslint",
    "lint:write": "rslint --fix"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.5",
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.6.5",
    "@rstest/core": "^0.11.1",
    "@types/node": "^24.13.3",
    "prettier": "^3.9.5",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.13.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
